# Bybit API (key issued by Tiger broker, used directly against Bybit)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=1

# Telegram
TELEGRAM_BOT_TOKEN=
# Comma-separated chat_ids — bootstrap only; runtime allow-list lives in DB (TelegramUser)
TELEGRAM_ALLOWED_CHAT_IDS=

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Infrastructure
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=

# Trader behaviour
# Set to 1 to log all orders without actually placing them on Bybit (smoke-test mode)
TRADER_DRY_RUN=0
