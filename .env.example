# Bybit API (key issued by Tiger broker, used directly against Bybit)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=1

# Telegram
TELEGRAM_BOT_TOKEN=

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Infrastructure
# sqlite for local dev, or Postgres:
#   postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=

# Trader behaviour
# Set to 1 to log all orders without actually placing them on Bybit (smoke-test mode)
TRADER_DRY_RUN=0
# Set to 1 to bypass the single-instance startup guard (a fresh heartbeat otherwise
# blocks a second trader from starting). Enable only where one instance is guaranteed.
TRADER_SKIP_INSTANCE_GUARD=0
